.DS_Store
._*
Thumbs.db

__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

.env
.env.*
*.log
*.tmp
*.temp
*.swp
*.bak
.tmp/

# Large local model artifacts.
*.gguf
*.safetensors
*.bin
*.pt
*.pth
*.onnx

# Runtime logs and temporary outputs.
06_logs/*
!06_logs/.gitkeep

# Raw archives can be large and private.
# Remove this block in a private vault if you want Git to manage original files.
01_raw_archive/*
!01_raw_archive/.gitkeep

# User inbox files should not be committed.
00_inbox/*
!00_inbox/.gitkeep

# Parsed outputs are generated from private source files.
02_parsed/*
!02_parsed/.gitkeep

# Drafts are usually local/private.
05_drafts/*
!05_drafts/.gitkeep
